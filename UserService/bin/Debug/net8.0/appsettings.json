{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/userservice-.log",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Jwt": {
    "SecretKey": "VehicleServiceBooking@2026#TeamSecret!Key",
    "Issuer": "UserService",
    "Audience": "VehicleService,BookingService,InvoiceService",
    "ExpiryMinutes": 60
  },
  "ConnectionStrings": {
    "UserDetails": "Server=.\\sqlexpress;initial catalog=UserDetails;integrated security=true; trustservercertificate=true;"
  },
  "AllowedHosts": "*"
}